# Node environment
NODE_ENV=production

# Rootstock network selection: "mainnet" | "testnet"
RSK_NETWORK=mainnet

# Override default public RPC endpoints (optional)
RSK_MAINNET_RPC_URL=https://public-node.rsk.co
RSK_TESTNET_RPC_URL=https://public-node.testnet.rsk.co

# WebSocket RPC URL for event monitoring.
# Leave blank to use HTTP block polling (works with public RSK nodes out of the box).
# RSK public nodes (public-node.rsk.co) are HTTP-only and do not support WebSocket.
# Set this only if using a WS-capable provider:
#   dRPC:    wss://rootstock.drpc.org
#   GetBlock: wss://rsk.getblock.io/<API_KEY>/mainnet
#   Tatum:   wss://rsk.tatum.io/v3/<API_KEY>/broadcast
RSK_MAINNET_WS_URL=
RSK_TESTNET_WS_URL=

# MCP server transport: "stdio" | "http"
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3000

# Session key defaults
SESSION_DEFAULT_TTL_SECONDS=3600
SESSION_MAX_SPEND_RBTC=0.01

# Policy engine: comma-separated contract addresses to add beyond the built-in whitelist
POLICY_CONTRACT_WHITELIST=

# Audit log destination: "console" | "file"
AUDIT_LOG_DESTINATION=console
AUDIT_LOG_FILE_PATH=./audit.log
